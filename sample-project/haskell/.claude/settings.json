{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(stack test:*)",
      "Read(**)",
      "Edit(docs/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-stack-build.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | xargs -r pre-commit run --files || true"
          }
        ]
      }
    ]
  }
}
