{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_MICROCOMPACT": "true"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "WebFetch",
      "WebSearch",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(realpath:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch --list:*)",
      "Bash(git branch -v:*)",
      "Bash(git branch -a:*)",
      "Bash(git branch -r:*)",
      "Bash(git fetch:*)",
      "Bash(git remote)",
      "Bash(git remote -v)",
      "Bash(git remote get-url:*)",
      "Bash(git remote show:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git blame:*)",
      "Bash(git stash list)",
      "Bash(git stash show:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list:*)",
      "Bash(git tag)",
      "Bash(git tag --list:*)",
      "Bash(git tag -l:*)",
      "Bash(git describe:*)",
      "Bash(git reflog:*)",
      "Bash(git shortlog:*)",
      "Bash(git cat-file:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(git for-each-ref:*)",
      "Bash(git worktree list)",
      "Bash(git grep:*)"
    ]
  }
}
